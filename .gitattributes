# Normalize line endings: store everything as LF in the repo so Windows checkouts
# don't trigger "LF will be replaced by CRLF" warnings or noisy diffs.
* text=auto eol=lf

# Windows-only scripts keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Treat common binaries as binary (no EOL conversion, no diff).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.woff  binary
*.woff2 binary
